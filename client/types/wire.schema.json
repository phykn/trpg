{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "ErrorPayload": {
      "properties": {
        "code": {
          "title": "Code",
          "type": "string"
        },
        "message": {
          "title": "Message",
          "type": "string"
        }
      },
      "required": [
        "code",
        "message"
      ],
      "title": "ErrorPayload",
      "type": "object"
    },
    "TierBadge": {
      "description": "Difficulty tier display: numeric position (value/max) plus localized label.",
      "properties": {
        "value": {
          "title": "Value",
          "type": "integer"
        },
        "max": {
          "title": "Max",
          "type": "integer"
        },
        "label": {
          "title": "Label",
          "type": "string"
        }
      },
      "required": [
        "value",
        "max",
        "label"
      ],
      "title": "TierBadge",
      "type": "object"
    },
    "PendingCheckPayload": {
      "description": "Wire shape for the `pending_check` SSE event and the `pendingCheck` slot\ninside the `state` payload.",
      "properties": {
        "kind": {
          "enum": [
            "stat",
            "recruit"
          ],
          "title": "Kind",
          "type": "string"
        },
        "dc": {
          "title": "Dc",
          "type": "integer"
        },
        "stat": {
          "title": "Stat",
          "type": "string"
        },
        "stat_label": {
          "title": "Stat Label",
          "type": "string"
        },
        "stat_value": {
          "title": "Stat Value",
          "type": "integer"
        },
        "mod": {
          "title": "Mod",
          "type": "integer"
        },
        "required_roll": {
          "title": "Required Roll",
          "type": "integer"
        },
        "tier": {
          "$ref": "#/definitions/TierBadge"
        },
        "target": {
          "title": "Target",
          "type": "string"
        },
        "reason": {
          "title": "Reason",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "dc",
        "stat",
        "stat_label",
        "stat_value",
        "mod",
        "required_roll",
        "tier",
        "target",
        "reason"
      ],
      "title": "PendingCheckPayload",
      "type": "object"
    },
    "EquipItem": {
      "description": "Equipped item display — name only (qty implicit = 1).",
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "title": "EquipItem",
      "type": "object"
    },
    "Equipment": {
      "description": "Hero/subject equipment slots. Mirrors domain.Equipment field set.",
      "properties": {
        "weapon": {
          "anyOf": [
            {
              "$ref": "#/definitions/EquipItem"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "armor": {
          "anyOf": [
            {
              "$ref": "#/definitions/EquipItem"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "accessory": {
          "anyOf": [
            {
              "$ref": "#/definitions/EquipItem"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "title": "Equipment",
      "type": "object"
    },
    "InventoryItem": {
      "description": "Inventory row: item name + quantity.",
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "qty": {
          "title": "Qty",
          "type": "integer"
        }
      },
      "required": [
        "name",
        "qty"
      ],
      "title": "InventoryItem",
      "type": "object"
    },
    "StatEntry": {
      "description": "One row of the stats display: localized label + numeric value.",
      "properties": {
        "label": {
          "title": "Label",
          "type": "string"
        },
        "value": {
          "title": "Value",
          "type": "integer"
        }
      },
      "required": [
        "label",
        "value"
      ],
      "title": "StatEntry",
      "type": "object"
    },
    "HeroPayload": {
      "description": "Wire shape for the `hero` slot inside the `state` payload.",
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "alive": {
          "title": "Alive",
          "type": "boolean"
        },
        "raceJob": {
          "title": "Racejob",
          "type": "string"
        },
        "gender": {
          "title": "Gender",
          "type": "string"
        },
        "level": {
          "title": "Level",
          "type": "integer"
        },
        "exp": {
          "title": "Exp",
          "type": "integer"
        },
        "expMax": {
          "title": "Expmax",
          "type": "integer"
        },
        "canLevelUp": {
          "title": "Canlevelup",
          "type": "boolean"
        },
        "hp": {
          "title": "Hp",
          "type": "integer"
        },
        "hpMax": {
          "title": "Hpmax",
          "type": "integer"
        },
        "mp": {
          "title": "Mp",
          "type": "integer"
        },
        "mpMax": {
          "title": "Mpmax",
          "type": "integer"
        },
        "reviveCoins": {
          "title": "Revivecoins",
          "type": "integer"
        },
        "reviveCoinsMax": {
          "title": "Revivecoinsmax",
          "type": "integer"
        },
        "gold": {
          "title": "Gold",
          "type": "integer"
        },
        "stats": {
          "items": {
            "$ref": "#/definitions/StatEntry"
          },
          "title": "Stats",
          "type": "array"
        },
        "equipment": {
          "$ref": "#/definitions/Equipment"
        },
        "inventory": {
          "items": {
            "$ref": "#/definitions/InventoryItem"
          },
          "title": "Inventory",
          "type": "array"
        },
        "status": {
          "items": {
            "type": "string"
          },
          "title": "Status",
          "type": "array"
        },
        "skills": {
          "items": {
            "type": "string"
          },
          "title": "Skills",
          "type": "array"
        },
        "companions": {
          "items": {
            "type": "string"
          },
          "title": "Companions",
          "type": "array"
        }
      },
      "required": [
        "name",
        "alive",
        "raceJob",
        "gender",
        "level",
        "exp",
        "expMax",
        "canLevelUp",
        "hp",
        "hpMax",
        "mp",
        "mpMax",
        "reviveCoins",
        "reviveCoinsMax",
        "gold",
        "stats",
        "equipment",
        "inventory",
        "status",
        "skills",
        "companions"
      ],
      "title": "HeroPayload",
      "type": "object"
    },
    "SubjectPayload": {
      "description": "Wire shape for the `subject` slot inside the `state` payload.\nField order matches mapping/to_front.to_subject's dict insertion order.\nNPC mp/mpMax is intentionally absent — subject panel doesn't expose\nNPC mana to the player.",
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "alive": {
          "title": "Alive",
          "type": "boolean"
        },
        "role": {
          "title": "Role",
          "type": "string"
        },
        "raceJob": {
          "title": "Racejob",
          "type": "string"
        },
        "gender": {
          "title": "Gender",
          "type": "string"
        },
        "trust": {
          "title": "Trust",
          "type": "integer"
        },
        "known": {
          "items": {
            "type": "string"
          },
          "title": "Known",
          "type": "array"
        },
        "level": {
          "title": "Level",
          "type": "integer"
        },
        "hp": {
          "title": "Hp",
          "type": "integer"
        },
        "hpMax": {
          "title": "Hpmax",
          "type": "integer"
        },
        "stats": {
          "items": {
            "$ref": "#/definitions/StatEntry"
          },
          "title": "Stats",
          "type": "array"
        },
        "equipment": {
          "$ref": "#/definitions/Equipment"
        },
        "inventory": {
          "items": {
            "$ref": "#/definitions/InventoryItem"
          },
          "title": "Inventory",
          "type": "array"
        },
        "skills": {
          "items": {
            "type": "string"
          },
          "title": "Skills",
          "type": "array"
        }
      },
      "required": [
        "name",
        "alive",
        "role",
        "raceJob",
        "gender",
        "trust",
        "known",
        "level",
        "hp",
        "hpMax",
        "stats",
        "equipment",
        "inventory",
        "skills"
      ],
      "title": "SubjectPayload",
      "type": "object"
    },
    "DifficultyBadge": {
      "description": "Difficulty visual atom for the quest panel: localized label + tone hint\n(the latter aligns with client `Tone` design-system literals; the 5-value\nsubset matches mapping.labels._TIER_TONE).",
      "properties": {
        "label": {
          "title": "Label",
          "type": "string"
        },
        "tone": {
          "anyOf": [
            {
              "enum": [
                "neutral",
                "good",
                "exp",
                "accent",
                "bad"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tone"
        }
      },
      "required": [
        "label"
      ],
      "title": "DifficultyBadge",
      "type": "object"
    },
    "QuestRewards": {
      "description": "Wire view of quest rewards — gold + exp only. Domain QuestRewards also\ncarries `items: list[str]` but the quest panel doesn't surface them today.",
      "properties": {
        "gold": {
          "title": "Gold",
          "type": "integer"
        },
        "exp": {
          "title": "Exp",
          "type": "integer"
        }
      },
      "required": [
        "gold",
        "exp"
      ],
      "title": "QuestRewards",
      "type": "object"
    },
    "QuestPayload": {
      "description": "Wire shape for the `quest` slot inside the `state` payload.\nField order matches mapping/to_front.to_quest's dict insertion order.\n`status` / `actions` are narrowed to the four/two literals to_quest can\nemit — domain Quest.status carries `locked`/`abandoned` too but those\nnever reach the active-quest path.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "title": {
          "title": "Title",
          "type": "string"
        },
        "summary": {
          "title": "Summary",
          "type": "string"
        },
        "giver": {
          "title": "Giver",
          "type": "string"
        },
        "difficulty": {
          "$ref": "#/definitions/DifficultyBadge"
        },
        "goals": {
          "items": {
            "type": "string"
          },
          "title": "Goals",
          "type": "array"
        },
        "progressLabel": {
          "title": "Progresslabel",
          "type": "string"
        },
        "conditions": {
          "items": {
            "type": "string"
          },
          "title": "Conditions",
          "type": "array"
        },
        "rewards": {
          "$ref": "#/definitions/QuestRewards"
        },
        "status": {
          "enum": [
            "pending",
            "active",
            "completed",
            "failed"
          ],
          "title": "Status",
          "type": "string"
        },
        "actions": {
          "items": {
            "enum": [
              "accept",
              "abandon"
            ],
            "type": "string"
          },
          "title": "Actions",
          "type": "array"
        }
      },
      "required": [
        "id",
        "title",
        "summary",
        "giver",
        "difficulty",
        "goals",
        "progressLabel",
        "conditions",
        "rewards",
        "status",
        "actions"
      ],
      "title": "QuestPayload",
      "type": "object"
    }
  }
}
