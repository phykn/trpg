# Production env. Copy to .env.release (gitignored) and fill in the secrets.
# Loaded when APP_ENV=release. Provider blocks (.env.llama_cpp / .env.google)
# layer on top, same as dev — but route a hosted provider, not local llama.cpp.

HOST = 0.0.0.0
PORT = 8001
BASIC_AUTH_USER =
BASIC_AUTH_PASS =
CORS_ORIGINS =

# Supabase — service role key bypasses RLS. Server-only secret. Bucket
# layout mirrors scenarios/<profile>/... 1:1 (see server/CLAUDE.md).
SUPABASE_URL =
SUPABASE_SERVICE_KEY =
SUPABASE_SCENARIO_BUCKET = scenarios

# LLM routing — hosted provider only. Local llama.cpp isn't reachable
# from a deployed Worker / Container, so route everything through Gemini
# (or another hosted OpenAI-compat provider).
LLM_ROUTE_DEFAULT = google/gemma-4-26b-a4b-it
LLM_ROUTE_NARRATE = google/gemma-4-31b-it
